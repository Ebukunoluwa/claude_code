# ── LiveKit ──────────────────────────────────────────────────────────────────
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxx
LIVEKIT_API_SECRET=your_livekit_api_secret

# ── Deepgram (STT) ───────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key

# ── Cartesia (TTS) ───────────────────────────────────────────────────────────
CARTESIA_API_KEY=your_cartesia_api_key
# Cartesia voice ID for a British English voice
CARTESIA_VOICE_ID=a0e99841-438c-4a64-b679-ae501e7d6091

# ── Groq (LLM) ───────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama3-70b-8192

# ── Twilio (Telephony) ───────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+441234567890
TWILIO_SIP_TRUNK_ID=TKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Storage ───────────────────────────────────────────────────────────────────
SQLITE_DB_PATH=data/healthcare.db
CHROMA_PERSIST_PATH=data/chroma

# ── Dashboard ────────────────────────────────────────────────────────────────
DASHBOARD_SECRET_KEY=change-me-in-production-use-secrets-module
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# ── Scheduler ────────────────────────────────────────────────────────────────
SCHEDULER_POLL_INTERVAL_SECONDS=60
